# Copy this to .env and fill in your keys
# .env is gitignored — never commit it

# AI Providers — LLM Council (need at least ONE, more = better reliability)
GROQ_API_KEY=            # https://console.groq.com/keys (free: 30 RPM)
OPENROUTER_API_KEY=      # https://openrouter.ai/keys (free models)
NVIDIA_API_KEY=          # https://build.nvidia.com (free credits)
QWEN_API_KEY=            # https://dashscope.console.aliyun.com (free tier)
DEEPSEEK_API_KEY=        # https://platform.deepseek.com (free tier)
ANTHROPIC_API_KEY=       # https://console.anthropic.com (paid, optional)

# Job Scraper APIs (optional — browser scrapers work without these)
SERPAPI_API_KEY=
JSEARCH_API_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Email notifications (optional)
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
NOTIFY_EMAIL=
