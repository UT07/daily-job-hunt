# Copy this to .env and fill in your keys
# .env is gitignored — never commit it

# AI Providers (need at least ONE)
GROQ_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Job Scraper APIs (optional — browser scrapers work without these)
SERPAPI_API_KEY=
JSEARCH_API_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Email notifications (optional)
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
NOTIFY_EMAIL=
