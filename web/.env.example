# API URL — set this to your deployed FastAPI backend
# For local development, leave empty (Vite proxy handles it)
# For Netlify, set in Netlify env vars dashboard
VITE_API_URL=

# PostHog Project API key (phc_*). Public — safe to commit.
# Empty value disables analytics in this build.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.i.posthog.com
